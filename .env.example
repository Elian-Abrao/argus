# =============================================================================
# Argus — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# PostgreSQL
POSTGRES_USER=argus
POSTGRES_PASSWORD=change-me
POSTGRES_DB=argus_db

# API — Database & Message Broker
ARGUS_API_DATABASE_URL=postgresql+psycopg://argus:change-me@postgres:5432/argus_db
ARGUS_API_RABBITMQ_URL=amqp://guest:change-me@rabbitmq:5672/

# API — Authentication
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
ARGUS_API_JWT_SECRET=change-me-generate-a-secure-random-value
ARGUS_API_COOKIE_SECURE=true

# API — MinIO (object storage)
ARGUS_API_MINIO_ENDPOINT=minio:9000
ARGUS_API_MINIO_ACCESS_KEY=change-me
ARGUS_API_MINIO_SECRET_KEY=change-me
ARGUS_API_MINIO_BUCKET=argus-email-attachments
ARGUS_API_MINIO_SECURE=false
ARGUS_MINIO_API_HOST_PORT=9010
ARGUS_MINIO_CONSOLE_HOST_PORT=9011

# API — Data retention & cleanup
ARGUS_API_EMAIL_RETENTION_DAYS_DEFAULT=7
ARGUS_API_EMAIL_RETENTION_CLEANUP_ENABLED=true
ARGUS_API_EMAIL_RETENTION_CLEANUP_INTERVAL_SECONDS=3600
ARGUS_API_EMAIL_RETENTION_CLEANUP_BATCH_SIZE=500
ARGUS_API_RUN_STALE_CLEANUP_ENABLED=true
ARGUS_API_RUN_STALE_TIMEOUT_HOURS=24
ARGUS_API_RUN_STALE_CLEANUP_INTERVAL_SECONDS=300
ARGUS_API_RUN_STALE_CLEANUP_BATCH_SIZE=500

# Dashboard
ARGUS_API_BASE_URL=http://argus-api:8100/api

# TLS / Certificates (production Nginx)
ARGUS_CERT_DIR=/etc/letsencrypt/live/your-domain.com
ARGUS_ACME_DIR=./certbot-public

# Branding
ARGUS_PLATFORM_NAME=Argus
ARGUS_AI_NAME=Argus AI
ARGUS_AI_LANGUAGE=en
ARGUS_PRIMARY_COLOR=#6366f1
ARGUS_LOGO_URL=
ARGUS_AI_AVATAR_URL=/ai/avatar.webp
