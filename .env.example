# =============================================================================
# Argus - Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# On Windows, set HOME explicitly if Docker Compose does not inherit it.
# Example: HOME=C:/Users/your-user

# PostgreSQL
POSTGRES_USER=argus
POSTGRES_PASSWORD=change-me
POSTGRES_DB=argus_db

# Remote API - Database & Message Broker
LOGGER_API_DATABASE_URL=postgresql+psycopg://argus:change-me@postgres:5432/argus_db
LOGGER_API_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Remote API - Authentication
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
LOGGER_API_JWT_SECRET=change-me-generate-a-secure-random-value
# Set to false for local HTTP access without TLS.
LOGGER_API_COOKIE_SECURE=true

# Remote API - MinIO (object storage)
LOGGER_API_MINIO_ENDPOINT=minio:9000
LOGGER_API_MINIO_ACCESS_KEY=change-me
LOGGER_API_MINIO_SECRET_KEY=change-me
LOGGER_API_MINIO_BUCKET=argus-email-attachments
LOGGER_API_MINIO_SECURE=false
LOGGER_MINIO_API_HOST_PORT=9010
LOGGER_MINIO_CONSOLE_HOST_PORT=9011

# Remote API - Data retention & cleanup
LOGGER_API_EMAIL_RETENTION_DAYS_DEFAULT=7
LOGGER_API_EMAIL_RETENTION_CLEANUP_ENABLED=true
LOGGER_API_EMAIL_RETENTION_CLEANUP_INTERVAL_SECONDS=3600
LOGGER_API_EMAIL_RETENTION_CLEANUP_BATCH_SIZE=500
LOGGER_API_RUN_STALE_CLEANUP_ENABLED=true
LOGGER_API_RUN_STALE_TIMEOUT_HOURS=24
LOGGER_API_RUN_STALE_CLEANUP_INTERVAL_SECONDS=300
LOGGER_API_RUN_STALE_CLEANUP_BATCH_SIZE=500

# Dashboard
ARGUS_API_BASE_URL=http://argus-api:8100/api

# TLS / Certificates (production Nginx)
ARGUS_CERT_DIR=/etc/letsencrypt/live/your-domain.com
ARGUS_ACME_DIR=./certbot-public

# Branding
ARGUS_PLATFORM_NAME=Argus
ARGUS_AI_NAME=Argus AI
ARGUS_AI_LANGUAGE=en
ARGUS_PRIMARY_COLOR=#6366f1
ARGUS_LOGO_URL=
ARGUS_AI_AVATAR_URL=/ai/avatar.webp
